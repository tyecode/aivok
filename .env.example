# aivok — environment variables
# Copy to .env and fill in your API keys

# === Required: at least one ===
# Get free keys at the URLs below (no credit card needed for free tiers)

# Gemini (recommended) — 15 RPM, 1M context
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq — 30 RPM, fastest inference
# https://console.groq.com/keys
GROQ_API_KEY=

# === Optional: additional providers ===

# Anthropic (Claude) — limited free credits on signup
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Mistral — free models available
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Cohere — trial credits
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# === OpenAI-compatible (custom) ===
# For Ollama, OpenRouter, DeepSeek, xAI, etc.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1